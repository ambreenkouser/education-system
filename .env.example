# ============================================================
# EduManage Pro — Required Environment Variables
# Copy to .env and fill in all values before running in prod.
# .env must NEVER be committed to source control.
# ============================================================

# --- Database (shared credentials across services) ---
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=edumanage
DB_PASSWORD=<strong-password-here>

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<strong-redis-password>
REDIS_SSL=true

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Service Discovery ---
EUREKA_URL=http://discovery-server:8761/eureka/

# --- Distributed Tracing ---
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
TRACING_PROBABILITY=0.1

# --- JWT (auth-service + api-gateway MUST share the same value) ---
JWT_SECRET=<min-64-char-random-string-generate-with-openssl-rand-base64-64>
JWT_EXPIRY_MS=900000

# --- Login Rate Limiting ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# --- Email (notification-service) ---
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=<app-specific-password>

# --- Feature Flags ---
SWAGGER_ENABLED=false   # Always false in production

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=prod
